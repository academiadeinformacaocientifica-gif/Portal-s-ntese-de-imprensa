rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function emailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "nosnadiaspora@gmail.com" || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidSummary(data) {
      return data.keys().hasAll(['dataReferencia', 'paisId', 'paisNome', 'tituloCapa', 'status', 'categorias', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 8 &&
             data.dataReferencia is string && data.dataReferencia.size() <= 50 &&
             data.paisId is string && data.paisId.size() <= 10 &&
             data.paisNome is string && data.paisNome.size() <= 100 &&
             data.tituloCapa is string && data.tituloCapa.size() <= 255 &&
             data.status in ['Hoje', 'Ontem', 'Arquivo'] &&
             data.categorias is list && data.categorias.size() <= 10 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidNews(data) {
      return data.keys().hasAll(['sinteseId', 'titulo', 'corpo', 'categoria', 'metadata', 'createdAt', 'updatedAt']) &&
             data.sinteseId is string && isValidId(data.sinteseId) &&
             data.titulo is string && data.titulo.size() <= 255 &&
             data.corpo is string && data.corpo.size() <= 20000 &&
             data.categoria is string &&
             data.metadata is map &&
             data.createdAt == request.time &&
             data.updatedAt == request.time &&
             existsAfter(/databases/$(database)/documents/summaries/$(data.sinteseId));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email == request.auth.token.email &&
             data.role in ['admin', 'editor', 'reader'];
    }

    // --- Collection Rules ---

    match /summaries/{summaryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSummary(incoming()) && isValidId(summaryId);
      allow update: if isAdmin() && 
                    incoming().updatedAt == request.time &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['tituloCapa', 'status', 'categorias', 'updatedAt', 'totalNoticias']);
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNews(incoming()) && isValidId(newsId);
      allow update: if isAdmin() && 
                    incoming().updatedAt == request.time &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['titulo', 'corpo', 'categoria', 'metadata', 'updatedAt', 'ordem']);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().role == 'reader'; // Default role
      allow update: if isAdmin() && 
                    incoming().email == existing().email &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName']);
      allow delete: if isAdmin();
    }
  }
}
